---
import { getCollection } from 'astro:content';
import PageLayout from '../../components/layout/PageLayout.astro';
import { categories } from '../../config/site';
const docs = (await getCollection('docs')).filter((entry) => !entry.data.draft).sort((a,b) => a.data.category.localeCompare(b.data.category) || a.data.order - b.data.order);
---
<PageLayout title="LLM Notes 文档 | LLM Notes 大模型学习与工程实践指南" description="按知识体系组织的大模型学习文档，覆盖 LLM、RAG、Agent、多模态、强化学习、推荐系统和 AI 工程部署。">
  <section class="section"><p class="eyebrow">Docs</p><h1>LLM Notes 文档</h1><p class="lead">按知识体系组织的大模型学习文档。你可以像刷 JavaGuide / 代码随想录一样，沿着清晰目录长期推进。</p></section>
  <section class="section"><div class="section-head"><div><h2>快速入口</h2><p>先选主题，再按章节顺序阅读。</p></div></div><div class="card-grid">{categories.map((item) => <a class="card" href={item.href}><h3>{item.title}</h3><p>{item.description}</p></a>)}</div></section>
  <section class="section"><h2>推荐阅读路径</h2><div class="route-list"><a href="/docs/transformer/attention-four-tokens"><span>1</span><div><strong>先学 Transformer</strong><p>从 Attention 到 GPT，建立模型结构直觉。</p></div></a><a href="/docs/llm-basics/what-is-llm"><span>2</span><div><strong>再学 LLM 训练与微调</strong><p>理解预训练、SFT、RLHF、DPO 与推理参数。</p></div></a><a href="/docs/rag/what-is-rag"><span>3</span><div><strong>然后学 RAG 与 Agent</strong><p>把模型能力接入知识库、工具和工作流。</p></div></a><a href="/projects/code-agent"><span>4</span><div><strong>最后做项目和面试准备</strong><p>用项目讲清业务问题、技术路线和优化空间。</p></div></a></div></section>
  <section class="section"><h2>全部文档</h2><div class="article-list">{docs.map((entry) => <a class="article-row" href={'/docs/' + entry.id}><strong>{entry.data.title}</strong><p>{entry.data.description}</p><div class="meta"><span>{entry.data.section}</span><span>{entry.data.difficulty}</span></div></a>)}</div></section>
</PageLayout>
